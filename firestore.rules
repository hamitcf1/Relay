rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user's role from their document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user is GM
    function isGM() {
      return isAuthenticated() && getUserRole() == 'gm';
    }
    
    // Helper function to check if user belongs to the hotel
    function belongsToHotel(hotelId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.hotel_id == hotelId;
    }
    
    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // ==========================================
    // HOTELS COLLECTION
    // ==========================================
    match /hotels/{hotelId} {
      // Anyone authenticated can read hotel info
      allow read: if isAuthenticated();
      
      // Anyone can create a hotel (during registration)
      allow create: if isAuthenticated();
      
      // Only GM or hotel creator can update hotel
      allow update: if isAuthenticated() && (
        isGM() ||
        resource.data.created_by == request.auth.uid
      );
      
      // Only GMs can delete hotels
      allow delete: if isGM();
      
      // ----------------------------------------
      // HOTEL SUBCOLLECTIONS
      // ----------------------------------------
      
      // LOGS - Real-time activity logs
      match /logs/{logId} {
        allow read, write: if true;
      }
      
      // SHIFTS - Shift records
      match /shifts/{shiftId} {
        allow read, write: if true;
      }
      
      // ROSTER - Weekly schedules
      match /roster/{weekId} {
        allow read, write: if true;
      }
      
      // INCIDENTS - Incident reports
      match /incidents/{incidentId} {
        allow read, write: if true;
      }
      
      // SHIFT_NOTES - Notes for all shifts
      match /shift_notes/{noteId} {
        allow read, write: if true;
      }
      
      // SETTINGS - Hotel settings
      match /settings/{settingId} {
        allow read, write: if true;
      }
      
      // ACTIVITY_LOGS - Staff activity audit trail
      match /activity_logs/{logId} {
        allow read, write: if true;
      }

      // NOTIFICATIONS
      match /notifications/{notifId} {
        allow read, write: if true;
      }

      // DAILY_MENU
      match /daily_menu/{menuId} {
        allow read, write: if true;
      }

      // TOURS
      match /tours/{tourId} {
        allow read, write: if true;
      }

      // ROOMS
      match /rooms/{roomId} {
        allow read, write: if true;
      }

      // SALES
      match /sales/{saleId} {
        allow read, write: if true;
      }

      // CALENDAR_EVENTS
      match /calendar_events/{eventId} {
        allow read, write: if true;
      }

      // OFF_DAY_REQUESTS
      match /off_day_requests/{requestId} {
        allow read, write: if true;
      }

      // MESSAGES - Private messaging
      match /messages/{messageId} {
        allow read, write: if true;
      }

      // ANONYMOUS_FEEDBACK
      match /anonymous_feedback/{feedbackId} {
        allow read, write: if true;
      }

      // BLACKLISTS
      match /blacklists/{guestId} {
        allow read, write: if true;
      }

      // PRICING - Complex nested structure
      match /pricing/{configId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
        
        // Handle sub-subcollections under pricing
        match /{allChildren=**} {
           allow read: if isAuthenticated() && belongsToHotel(hotelId);
           allow write: if isGM();
        }
      }
    }
  }
}
