rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get the current user's document
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if user is active
    function isActiveEmployee() {
      let userDoc = getUserDoc();
      return !('status' in userDoc) || userDoc.status != 'inactive';
    }
    
    // Helper function to get user's role from their document
    function getUserRole() {
      return getUserDoc().role;
    }
    
    // Helper function to check if user is GM
    function isGM() {
      return isAuthenticated() && isActiveEmployee() && getUserRole() == 'gm';
    }
    
    // Helper function to check if user belongs to the hotel
    function belongsToHotel(hotelId) {
      let userDoc = getUserDoc();
      return userDoc.hotel_id == hotelId && (!('status' in userDoc) || userDoc.status != 'inactive');
    }
    
    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      // Users can read their own document
      // GMs can read any user in their hotel
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isGM() ||
        (resource != null && resource.data.hotel_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hotel_id)
      );
      
      // Users can only be created during registration (by themselves) OR by GMs
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && request.resource.data.role in ['receptionist', 'housekeeping']) ||
        isGM()
      );
      
      // Users can update their own non-role fields
      // Only GMs can update role field
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        isGM()
      );
      
      // Only GMs can delete users
      allow delete: if isGM();
    }
    
    // ==========================================
    // HOTELS COLLECTION
    // ==========================================
    match /hotels/{hotelId} {
      // Anyone authenticated can read hotel info
      allow read: if isAuthenticated();
      
      // Anyone can create a hotel (during registration)
      allow create: if isAuthenticated();
      
      // Only GM or hotel creator can update hotel
      allow update: if isAuthenticated() && (
        isGM() ||
        resource.data.created_by == request.auth.uid
      );
      
      // Only GMs can delete hotels
      allow delete: if isGM();
      
      // ----------------------------------------
      // HOTEL SUBCOLLECTIONS
      // ----------------------------------------
      
      // LOGS - Real-time activity logs
      match /logs/{logId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM();
      }
      
      // SHIFTS - Shift records
      match /shifts/{shiftId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM();
      }
      
      // ROSTER - Weekly schedules (GM can edit, all can read)
      match /roster/{weekId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
      }
      
      // INCIDENTS - Incident reports
      match /incidents/{incidentId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM();
      }
      
      // SHIFT_NOTES - Notes for all shifts
      match /shift_notes/{noteId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isAuthenticated() && (
          isGM() ||
          resource.data.created_by == request.auth.uid
        );
      }
      
      // SETTINGS - Hotel settings (GM only write)
      match /settings/{settingId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
      }
      
      // ACTIVITY_LOGS - Staff activity audit trail
      match /activity_logs/{logId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create, update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if false;

        // ActivityTracker stores the detailed five-minute segments below the
        // authenticated employee's deterministic daily activity document.
        match /sessions/{sessionId} {
          allow read: if isAuthenticated() && belongsToHotel(hotelId) && (
            isGM() || logId.matches('^' + request.auth.uid + '_.*')
          );
          allow create: if isAuthenticated()
            && belongsToHotel(hotelId)
            && logId.matches('^' + request.auth.uid + '_.*')
            && request.resource.data.keys().hasOnly([
              'start', 'end', 'duration_minutes'
            ])
            && request.resource.data.start is timestamp
            && request.resource.data.end is timestamp
            && request.resource.data.duration_minutes is number
            && request.resource.data.duration_minutes >= 0;
          allow update, delete: if false;
        }
      }

      // ATTENDANCE - Personal timekeeping records. Staff can only create and
      // close their own record; GMs can inspect the hotel's full report.
      match /attendance/{attendanceId} {
        // Clock-in uses a transaction get to prove that the deterministic
        // record does not exist yet. A missing document has no resource.data,
        // so own-ID gets must be authorized independently from list queries.
        allow get: if isAuthenticated() && belongsToHotel(hotelId) && (
          isGM()
          || attendanceId.matches('^.*_' + request.auth.uid + '_[A-Za-z0-9-]+$')
          || resource.data.staff_id == request.auth.uid
        );
        allow list: if isAuthenticated() && belongsToHotel(hotelId) && (
          isGM() || resource.data.staff_id == request.auth.uid
        );
        allow create: if isAuthenticated() && belongsToHotel(hotelId)
          && getUserRole() == 'receptionist'
          && attendanceId.matches('^.*_' + request.auth.uid + '_[A-Za-z0-9-]+$')
          && request.resource.data.staff_id == request.auth.uid
          && request.resource.data.status == 'clocked_in'
          && request.resource.data.staff_name == getUserDoc().name
          && request.resource.data.staff_role == 'receptionist'
          && request.resource.data.late_minutes >= 0
          && request.resource.data.reviewed_by == null
          && request.resource.data.reviewed_by_name == null
          && request.resource.data.reviewed_at == null
          && request.resource.data.review_note == null
          && (
            (
              request.resource.data.late_minutes > 0
              && request.resource.data.late_excuse is string
              && request.resource.data.late_excuse.size() > 0
              && request.resource.data.manager_permission_declared is bool
              && request.resource.data.approval_status == 'pending'
            ) || (
              request.resource.data.late_minutes == 0
              && request.resource.data.manager_permission_declared == null
              && request.resource.data.approval_status == 'not_required'
            )
          );
        allow update: if isAuthenticated() && belongsToHotel(hotelId) && (
          (
            resource.data.staff_id == request.auth.uid
            && resource.data.status == 'clocked_in'
            && request.resource.data.status == 'clocked_out'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'clock_out_at', 'status', 'worked_minutes', 'updated_at'
            ])
          ) || (
            isGM()
            && resource.data.late_minutes > 0
            && resource.data.approval_status == 'pending'
            && request.resource.data.approval_status in ['approved', 'rejected']
            && request.resource.data.reviewed_by == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'approval_status', 'reviewed_by', 'reviewed_by_name',
              'reviewed_at', 'review_note', 'updated_at'
            ])
          )
        );
        allow delete: if false;
      }

      // Immutable event trail for every clock-in and clock-out operation.
      match /attendance_events/{eventId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId) && isGM();
        allow create: if isAuthenticated() && belongsToHotel(hotelId) && (
          (getUserRole() == 'receptionist' && request.resource.data.staff_id == request.auth.uid) ||
          (isGM() && request.resource.data.event == 'manager_review' && request.resource.data.reviewed_by == request.auth.uid)
        );
        allow update, delete: if false;
      }

      // NOTIFICATIONS
      match /notifications/{notifId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isAuthenticated() && belongsToHotel(hotelId);
      }

      // DAILY_MENU
      match /daily_menu/{menuId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
      }

      // TOURS
      match /tours/{tourId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
      }

      // ROOMS
      match /rooms/{roomId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
      }

      // SALES
      match /sales/{saleId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM();
      }

      // CALENDAR_EVENTS
      match /calendar_events/{eventId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isAuthenticated() && belongsToHotel(hotelId);
      }

      // OFF_DAY_REQUESTS
      match /off_day_requests/{requestId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM() || (isAuthenticated() && resource.data.staff_id == request.auth.uid);
      }

      // MESSAGES - Private messaging
      match /messages/{messageId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM();
      }

      // ANONYMOUS_FEEDBACK
      match /anonymous_feedback/{feedbackId} {
        allow read: if isGM() && belongsToHotel(hotelId);
        allow create: if isAuthenticated(); // Allow any staff to submit anonymously
        allow update, delete: if isGM();
      }

      // BLACKLISTS
      match /blacklists/{guestId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update: if isAuthenticated() && belongsToHotel(hotelId);
        allow delete: if isGM() || (isAuthenticated() && resource.data.created_by == request.auth.uid);
      }

      // PRICING - Complex nested structure
      match /pricing/{configId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow write: if isGM();
        
        // Handle sub-subcollections under pricing
        match /{allChildren=**} {
           allow read: if isAuthenticated() && belongsToHotel(hotelId);
           allow write: if isGM();
        }
      }

      // SCORES - Office games leaderboard
      match /scores/{scoreId} {
        allow read: if isAuthenticated() && belongsToHotel(hotelId);
        allow create: if isAuthenticated() && belongsToHotel(hotelId);
        allow update, delete: if isGM();
      }
    }
  }
}
